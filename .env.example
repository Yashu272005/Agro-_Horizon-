# ── Server ──────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ── Database ─────────────────────────────
# Free PostgreSQL at https://neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# ── Auth ─────────────────────────────────
JWT_SECRET=replace_with_long_random_string

# ── Claude AI (for Disease Detector + Market Insights) ──
# Get from https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# ── India Market Data ─────────────────────
# Free at https://data.gov.in  (register takes 2 min)
DATA_GOV_KEY=your_data_gov_in_key
